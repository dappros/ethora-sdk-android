# Ethora Chat - Environment Configuration
# Copy to .env and adjust. Aligned with React (VITE_ETHORA_*) / preshent-mobile (PRESHENT_*)

# API
API_BASE_URL=https://api.ethoradev.com/v1
APP_ID=646cc8dc96d4a4dc8f7b2f2d
API_TOKEN=
# XMPP (APP_XMPP_SERVICE = WebSocket URL, XMPP_SERVICE = conference domain)
APP_XMPP_SERVICE=wss://xmpp.ethoradev.com:5443/ws
XMPP_SERVICE=conference.xmpp.ethoradev.com
XMPP_HOST=xmpp.ethoradev.com

# Optional: if set, auto-login with JWT (no login screen)
# USER_TOKEN=

# Optional: USE_PRESHENT_JWT_AUTH=true when using preshent API (users/client + x-custom-token)
# Default: false (ethora: v1/users/client + Authorization)
# USE_PRESHENT_JWT_AUTH=false

# Optional: DNS fallback for any project when emulator can't resolve host.
# Format: host1=ip1,host2=ip2 (get IP: nslookup hostname)
# Example preshent: xmpp-dev.preshent.com=34.174.203.35,api-dev.preshent.com=34.174.203.35,conference.xmpp-dev.preshent.com=34.174.203.35
# DNS_FALLBACK_OVERRIDES=

# Default login (for testing, when USER_TOKEN empty)
DEFAULT_LOGIN_EMAIL=yukiraze9@gmail.com
DEFAULT_LOGIN_PASSWORD=Qwerty123
